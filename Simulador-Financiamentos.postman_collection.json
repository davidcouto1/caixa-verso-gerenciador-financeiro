			"name": "Buscar Simulação por ID",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"if (pm.response.code === 200) {",
							"    var jsonData = pm.response.json();",
							"    pm.test(\"Simulação encontrada\", function () {",
							"        pm.expect(jsonData.id).to.be.a('number');",
							"        pm.expect(jsonData.valorInicial).to.be.a('number');",
							"        pm.expect(jsonData.valorTotalFinal).to.be.a('number');",
							"        pm.expect(jsonData.memoriaCalculos).to.be.an('array');",
							"    });",
							"}"
						],
						"type": "text/javascript"
					}
				}
			],
