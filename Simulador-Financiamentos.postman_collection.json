		{
			"name": "Criar Simulação - Básica",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"if (pm.response.code === 201) {",
							"    var jsonData = pm.response.json();",
							"    pm.environment.set(\"simulacao_id\", jsonData.id);",
							"    pm.test(\"Simulação criada com sucesso\", function () {",
							"        pm.expect(jsonData.id).to.be.a('number');",
							"        pm.expect(jsonData.valorInicial).to.eql(1000.00);",
							"        pm.expect(jsonData.taxaJurosMensal).to.eql(1.5);",
							"        pm.expect(jsonData.prazoMeses).to.eql(12);",
							"    });",
							"}"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"valorInicial\": 1000.00,\n  \"taxaJurosMensal\": 1.5,\n  \"prazoMeses\": 12\n}"
				},
				"url": {
					"raw": "http://localhost:8080/api/simulacoes",
					"protocol": "http",
					"host": [
						"localhost"
					],
					"port": "8080",
					"path": [
						"api",
						"simulacoes"
					]
				},
				"description": "Cria uma simulação básica: R$ 1.000,00 a 1,5% a.m. por 12 meses"
			},
			"response": []
		},
